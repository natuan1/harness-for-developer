{
  "name": "hybrid-harness",
  "version": "1.0.0",
  "description": "Hybrid harness engineering for AI coding agents — combines spec-driven development (Speckit), phased lifecycle (BMAD), and operational harness patterns (harness-creator).",
  "license": "MIT",
  "author": "Nguyen Anh Tuan",
  "repository": "https://github.com/nguyenanhtuan21/harness-for-developer",
  "languages": ["en"],
  "compatibility": {
    "minCliVersion": "0.1.0",
    "agents": [
      "claude-code",
      "codex-cli",
      "cursor",
      "windsurf",
      "generic"
    ]
  },
  "entryPoint": "SKILL.md",
  "references": [
    "references/memory-persistence-pattern.md",
    "references/context-engineering-pattern.md",
    "references/spec-driven-dev-pattern.md",
    "references/readiness-gate-pattern.md",
    "references/tool-registry-pattern.md",
    "references/multi-agent-pattern.md",
    "references/lifecycle-bootstrap-pattern.md",
    "references/gotchas.md"
  ],
  "triggers": [
    "hybrid harness",
    "spec-driven development",
    "harness engineering",
    "create harness",
    "specification workflow",
    "implementation readiness",
    "constitution",
    "AGENTS.md",
    "CLAUDE.md",
    "feature tracking",
    "session handoff",
    "phase routing",
    "agent reliability",
    "session continuity",
    "verification workflow",
    "scope control"
  ],
  "bundled": {
    "scripts": [],
    "assets": [],
    "templates": [
      "templates/agents.md",
      "templates/constitution.md",
      "templates/prd.md",
      "templates/architecture.md",
      "templates/feature-list.json",
      "templates/feature-list.schema.json",
      "templates/init.sh",
      "templates/progress.md",
      "templates/session-handoff.md"
    ]
  }
}
