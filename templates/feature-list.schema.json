{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Hybrid Feature List",
  "description": "Enhanced feature tracking with spec links, stories, acceptance criteria, and readiness gates",
  "type": "object",
  "properties": {
    "project": {
      "type": "string",
      "description": "Project name"
    },
    "constitution_path": {
      "type": "string",
      "description": "Path to project constitution"
    },
    "features": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique feature identifier",
            "pattern": "^feat-\\d+$"
          },
          "name": {
            "type": "string",
            "description": "Short feature name"
          },
          "description": {
            "type": "string",
            "description": "What this feature does"
          },
          "dependencies": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Feature IDs that must be done before this one"
          },
          "status": {
            "type": "string",
            "enum": ["not-started", "in-progress", "blocked", "done"],
            "description": "Current implementation state"
          },
          "gate_status": {
            "type": "string",
            "enum": ["pending", "passed", "concerns", "failed"],
            "description": "Implementation readiness gate result"
          },
          "spec_path": {
            "type": "string",
            "description": "Path to feature spec document"
          },
          "stories": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "id": {
                  "type": "string",
                  "pattern": "^story-\\d+-\\d+$"
                },
                "name": { "type": "string" },
                "status": {
                  "type": "string",
                  "enum": ["not-started", "in-progress", "blocked", "done"]
                },
                "evidence": { "type": "string" }
              },
              "required": ["id", "name", "status"]
            },
            "description": "Implementable stories within this feature"
          },
          "acceptance_criteria": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Testable criteria from spec"
          },
          "evidence": {
            "type": "string",
            "description": "Verification evidence when status is 'done'"
          }
        },
        "required": ["id", "name", "description", "status"]
      }
    }
  },
  "required": ["features"]
}
